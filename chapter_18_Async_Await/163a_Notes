// Promise:
// Represents a future result.

// async:
// Marks a function as asynchronous.
// Allows use of await.

// await:
// Waits until a Promise completes.

// Syntax:

async function test() {
    let result = await somePromise();
}


// Remember:
// async = permission to use await
// await = wait for Promise to finish

// Common in automation:
// Browser launch
// Page navigation
// API calls
// Database calls
// File operations


